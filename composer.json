{
    "name": "rvxlab/laravel-cronless-scheduler",
    "description": "Run Laravel's scheduler without cron jobs",
    "license": "MIT",
    "type": "library",
    "version": "0.0.1",
    "authors": [
        {
            "name": "RVxLab",
            "email": "code@rvx.works"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-pcntl": "*",
        "illuminate/console": "^12",
        "illuminate/support": "^12",
        "revolt/event-loop": "^1.0"
    },
    "require-dev": {
        "ergebnis/composer-normalize": "^2.48",
        "friendsofphp/php-cs-fixer": "^3.92",
        "orchestra/testbench": "^10.8",
        "phpstan/phpstan": "^2.1",
        "rector/rector": "^2.3",
        "rvxlab/php-cs-fixer-rules": "^2.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "RVxLab\\CronlessScheduler\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true
        },
        "sort-packages": true
    },
    "scripts": {
        "lint": "./vendor/bin/php-cs-fixer fix --config .php-cs-fixer.php",
        "phpstan": "./vendor/bin/phpstan analyze --memory-limit=-1",
        "rector": "./vendor/bin/rector",
        "artisan:symlink": "@php -r \"!file_exists('artisan') && !is_link('artisan') && symlink('vendor/bin/testbench', 'artisan');\"",
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "RVxLab\\CronlessScheduler\\Providers\\ServiceProvider"
            ]
        }
    }
}